<?xml version="1.0" encoding="utf-8"?>
<TemplateDescription name="fieldbuscomponent" basedOn="basecomponent" supportedFirmwareVersions="19.0.0.16199" requiredCliVersion="19.0.1.762" 
                     version="1.1" isRelevantForProjectNamespace="true" xmlns="http://www.phoenixcontact.com/schema/clitemplates">
   
  <Folder name="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])" />
  <File name="$(name).cpp" template="Component.cpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])" excludedForEmptyTemplate="true"/>
  <File name="$(name).hpp" template="Component.hpp" key="component" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])" excludedForEmptyTemplate="true"/>
  <File name="DataExchange.hpp" template="DataExchange.hpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal" excludedForEmptyTemplate="true"/>
  <File name="DataExchange.cpp" template="DataExchange.cpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal" excludedForEmptyTemplate="true"/>
  <File name="FieldbusData.hpp" template="FieldbusData.hpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal" excludedForEmptyTemplate="true"/>
  <File name="FieldbusData.cpp" template="FieldbusData.cpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal" excludedForEmptyTemplate="true"/>
  <File name="FieldbusSettings.hpp" template="FieldbusSettings.hpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal/Settings" excludedForEmptyTemplate="true"/>
  <File name="FieldbusSettings.cpp" template="FieldbusSettings.cpp" path="$([if-exist]output)$(output)$([else])$(path)$([end-if-exist])/Internal/Settings" excludedForEmptyTemplate="true"/>
  <Description>Create a new fieldbus component inside the component project.</Description>
  <Relationship name="project" type="fieldbusproject"/>
  <Example>
    <Arguments>
      <Argument name="name" value="NewComponent"/>
      <Argument name="path" value="Path/To/Project"/>
    </Arguments>
    <Description>creates a new fieldbus component 'NewComponent' in the 'src' directory with the root namespace of the project</Description>
  </Example>
  <Example>
    <Arguments>
      <Argument name="name" value="NewComponent"/>
      <Argument name="namespace" value="SomeNamespace"/>
      <Argument name="output" value="Folder"/>
      <Argument name="path" value="Path/To/Project"/>
    </Arguments>
    <Description>creates a new fieldbus component 'NewComponent' in the 'src/Folder' directory of the project with the namespace 'SomeNamespace'</Description>
  </Example>
</TemplateDescription>